# Discord OAuth verification
# Создай Discord Application на https://discord.com/developers/applications
# Добавь бота на свой сервер, скопируй token

# ID Discord сервера (гильдии), где должны состоять пользователи
DISCORD_SERVER_ID=your_discord_server_id_here

# Токен Discord бота (из Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
